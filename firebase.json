{
  "firestore": {
    "rules": "server/firestore/rules.rules",
    "indexes": "server/firestore/indexes.json"
  },
  "functions": [
    {
      "source": "server/functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log"
      ]
    }
  ],
  "hosting": {
    "public": "client/out",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "cleanUrls": true
  }
}
